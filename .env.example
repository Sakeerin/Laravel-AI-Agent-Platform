APP_NAME="AI Agent Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_agent_platform
DB_USERNAME=root
DB_PASSWORD=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434
AI_DEFAULT_MODEL=claude-sonnet

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use pusher (Soketi-compatible) for realtime: set BROADCAST_CONNECTION=pusher and PUSHER_* / VITE_PUSHER_* below
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Soketi or Pusher (Echo). Example for local Soketi: PUSHER_HOST=127.0.0.1 PUSHER_PORT=6001 PUSHER_SCHEME=http
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER=mt1

# Skill marketplace — optional: comma-separated hostnames allowed for user-defined HTTP webhook skills (empty = any host in non-production; set in production)
SKILLS_HTTP_WEBHOOK_ALLOWED_HOSTS=
# When false, is_premium marketplace packages return HTTP 402 on install (wire billing before disabling)
SKILLS_ALLOW_PREMIUM_WITHOUT_SUBSCRIPTION=true
# Phase 5 integrations (OAuth / API tokens)
GOOGLE_CALENDAR_ACCESS_TOKEN=
GMAIL_ACCESS_TOKEN=
NOTION_INTEGRATION_TOKEN=

# Phase 6 — security & ops
SECURITY_PROMPT_INJECTION_ENABLED=true
SECURITY_PROMPT_INJECTION_MODE=block
SECURITY_SYSTEM_HARDENING=true

# Sentry (optional — leave empty to disable)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Telescope (local debugging — off by default in production)
TELESCOPE_ENABLED=false

# External monitoring (configure in Uptime Robot / Azure Monitor — ping GET /up)

# Production Docker: point DB_HOST to mysql service name, enable Redis for queue/cache
# DB_HOST=mysql
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# Browser tool — optional Playwright screenshots (requires Node + `npx playwright install chromium` on the host; default PHP Docker image has no Node)
# BROWSER_PLAYWRIGHT_ENABLED=true
# BROWSER_PLAYWRIGHT_TIMEOUT=45
# BROWSER_PLAYWRIGHT_VIEWPORT=1280,720
# BROWSER_NPX_BINARY=npx
